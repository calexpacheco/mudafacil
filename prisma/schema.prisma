// MudaFácil — Prisma Schema
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Subscription fields
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripePriceId        String?
  stripeSubscriptionId String?   @unique
  subscriptionStart    DateTime?
  subscriptionEnd      DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?

  mudancas Mudanca[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Planos ─────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

// ─── Entidades MudaFácil ─────────────────────────────────────────────────────

model Item {
  id              String  @id @default(cuid())
  nome            String
  categoria       String
  iconeUrl        String
  larguraCm       Float
  alturaCm        Float
  profundidadeCm  Float
  pesoKg          Float
  volumeM3        Float
  isDefault       Boolean @default(true)

  mudancaItens MudancaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Caminhao {
  id            String       @id @default(cuid())
  nome          String
  tipo          TipoCaminhao
  capacidadeM3  Float
  capacidadeKg  Float
  comprimentoCm Float
  larguraCm     Float
  alturaCm      Float
  imagemUrl     String?

  mudancas     Mudanca[]
  cargaLayouts CargaLayout[]
  cotacoes     Cotacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TipoCaminhao {
  FIORINO
  HR
  TRES_QUARTOS
  BAU
}

model Transportadora {
  id              String         @id @default(cuid())
  nome            String
  logoUrl         String?
  notaMedia       Float          @default(0)
  totalAvaliacoes Int            @default(0)
  cidade          String
  tiposCaminhao   TipoCaminhao[]

  cotacoes Cotacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mudanca {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  enderecoOrigem  String
  enderecoDestino String
  dataDesejada    DateTime?
  caminhaoId      String?
  caminhao        Caminhao?     @relation(fields: [caminhaoId], references: [id])
  status          MudancaStatus @default(RASCUNHO)

  // Campos enriquecidos do cartão
  valorEstimadoCentavos Int?
  progressoPercentual   Float   @default(0)
  latOrigem             Float?
  lngOrigem             Float?
  latDestino            Float?
  lngDestino            Float?

  itens       MudancaItem[]
  cargaLayout CargaLayout?
  cotacoes    Cotacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MudancaStatus {
  RASCUNHO
  AGUARDANDO_COTACAO
  COTADO
  CONFIRMADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model MudancaItem {
  id         String  @id @default(cuid())
  mudancaId  String
  mudanca    Mudanca @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item    @relation(fields: [itemId], references: [id])
  quantidade Int     @default(1)
  observacao String?

  @@unique([mudancaId, itemId])
}

model CargaLayout {
  id                 String   @id @default(cuid())
  mudancaId          String   @unique
  mudanca            Mudanca  @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  caminhaoId         String
  caminhao           Caminhao @relation(fields: [caminhaoId], references: [id])
  itensPositionados  Json
  ocupacaoPercentual Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cotacao {
  id               String         @id @default(cuid())
  mudancaId        String
  mudanca          Mudanca        @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  transportadoraId String
  transportadora   Transportadora @relation(fields: [transportadoraId], references: [id])
  caminhaoId       String
  caminhao         Caminhao       @relation(fields: [caminhaoId], references: [id])
  precoCentavos    Int
  dataDisponivel   DateTime
  seguroIncluso    Boolean        @default(false)
  validade         DateTime
  contratada       Boolean        @default(false)

  // Dados desnormalizados do mock (nome da transportadora, etc.)
  nomeTransportadora String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
